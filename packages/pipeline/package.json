{
  "name": "@movie-quotes/pipeline",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "tsc --noEmit",
    "build": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "discover": "node --env-file=../../.env --import tsx src/stages/discover.ts",
    "fetch-scripts": "node --env-file=../../.env --import tsx src/stages/fetch-scripts.ts",
    "parse": "node --import tsx src/stages/parse.ts",
    "filter": "node --import tsx src/stages/filter.ts"
  },
  "dependencies": {
    "@movie-quotes/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
